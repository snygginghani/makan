# --- Database ---
DATABASE_URL=postgresql+asyncpg://makan:makan@localhost:5433/makan

# --- Auth ---
JWT_SECRET=generate-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Google Sign-In (optional; works on localhost / HTTPS domains, NOT LAN IPs) ---
GOOGLE_CLIENT_ID=
# Emails granted admin automatically (comma-separated)
ADMIN_EMAILS=

# --- Email verification (optional SMTP; without it, dev returns the code in the API) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Makan <no-reply@makan.jo>
SMTP_STARTTLS=true
# In production, set this to false so codes are never returned by the API:
EXPOSE_VERIFY_CODE_IN_DEV=true

# --- CORS (comma-separated) ---
# The app also allows localhost + private-LAN origins by regex automatically.
CORS_ORIGINS=http://localhost:3000

# --- LLM: DeepSeek (OpenAI-compatible) ---
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

# --- Embeddings ---
# "openai_compatible" for a real provider, "local" for offline dev/test (deterministic vectors)
EMBEDDING_PROVIDER=local
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Knowledge JSON storage ---
KNOWLEDGE_DIR=./data/knowledge

# --- Cloudinary ---
CLOUDINARY_URL=

# --- Rate limiting for /ai/query ---
AI_RATE_LIMIT=10/minute
